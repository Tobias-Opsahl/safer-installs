#!/usr/bin/env bash
set -e

# safer-npx: Safer alternative to npx, pnpx, bunx and pnpm dlx.
#
# Instead of downloading and executing a package directly, this creates a
# temporary folder, runs "pnpm add", runs the package and cleans up.
# This is safer with the combination of the pnpm configurations from
# safer-installs, since it performs security checks like not installing
# too recent versions of packages.

YELLOW=$'\033[1;33m'
RED=$'\033[1;31m'
GREEN=$'\033[1;32m'
RESET=$'\033[0m'
YELLOW_PREFIX="${YELLOW}[safer-npx]${RESET} "
GREEN_PREFIX="${GREEN}[safer-npx]${RESET} "
RED_PREFIX="${RED}[safer-npx]${RESET} "

if [ $# -eq 0 ]; then
    echo "${YELLOW_PREFIX}Usage: safer-npx <package> <arguments>"
    echo ""
    echo "  More Safely executes an npm package by installing it with pnpm "
    echo "  with better security settings (see ~/.config/pnpm/config.yaml for "
    echo "  more information), running it and then cleaning up. "
    exit 1
fi

ORIGINAL_DIR="$(pwd)"
TEMP_DIR=$(mktemp -d)
echo "${YELLOW_PREFIX}Created temporary directory $TEMP_DIR. "

cleanup() {
    echo "${YELLOW_PREFIX}Cleaning up by deleting temporary directory..."
    rm -rf "$TEMP_DIR"
    echo "${YELLOW_PREFIX}Cleanup done!"
}
trap cleanup EXIT

PACKAGE="$1"
shift

echo "${YELLOW_PREFIX}Installing $PACKAGE in temporary directory..."
echo ""

cd "$TEMP_DIR"
pnpm init
pnpm add "$PACKAGE"

# Remove everything before and including the symbol "/".
BIN_NAME="${PACKAGE##*/}"
BIN_PATH="$TEMP_DIR/node_modules/.bin/$BIN_NAME"

if [ ! -f "$BIN_PATH" ]; then
    echo ""
    echo "${RED_PREFIX}Could not find \"$BIN_NAME\" in package \"$PACKAGE\". "
    echo "  Available binaries:"
    ls "$TEMP_DIR/node_modules/.bin/" 2>/dev/null || echo "  (none)"
    exit 1
fi

echo ""
echo "${GREEN_PREFIX}Running: $BIN_NAME $*..."
echo ""

cd "$ORIGINAL_DIR"
"$BIN_PATH" "$@"
